# Salin ke `collector/.env` dan isi nilainya. Simpan sebagai UTF-8 TANPA BOM.
# JANGAN commit file .env yang sudah terisi.

# ── Cloudflare D1 (REST API) ─────────────────────────────────────
# Dari dashboard Cloudflare:
#   Account ID           : sidebar akun
#   D1 Database ID        : hasil `wrangler d1 create lagitren-db`
#   API Token             : buat token dengan izin "D1 Edit"
CLOUDFLARE_ACCOUNT_ID=
CLOUDFLARE_D1_DATABASE_ID=
CLOUDFLARE_API_TOKEN=

# ── YouTube Data API v3 ──────────────────────────────────────────
YOUTUBE_API_KEY=

# ── AI Summary (Ollama lokal) ────────────────────────────────────
OLLAMA_HOST=http://localhost:11434
OLLAMA_MODEL=gemma2:9b
# Backup: Claude Haiku (opsional). Kosongkan bila tidak dipakai.
ANTHROPIC_API_KEY=
ANTHROPIC_MODEL=claude-haiku-4-5
# Cache ringkasan: tren yang tak berubah tidak diringkas ulang (hemat biaya).
# Set 1 hanya bila ingin memaksa buat ulang semua ringkasan.
SUMMARY_FORCE_REFRESH=0

# ── Shopee Affiliate Open API (produk + tautan afiliasi resmi) ───
# Daftar di Shopee Affiliate Open Platform → dapat App ID & Secret.
# Kosongkan bila belum → collector Shopee otomatis dilewati.
SHOPEE_APP_ID=
SHOPEE_APP_SECRET=
# (Opsional) kata kunci kategori, dipisah koma. Default sudah diisi.
# SHOPEE_KEYWORDS=skincare,hp murah,fashion wanita,sepatu,gaming

# ── Instagram (kualitas) ─────────────────────────────────────────
# Ambang suka minimum agar sebuah post dianggap "hits" (buang recehan).
IG_MIN_LIKES=10000

# ── Netflix Top 10 (OTT) ─────────────────────────────────────────
# TMDB (gratis) untuk poster/sinopsis/rating. Daftar di themoviedb.org.
# Kosong → tetap jalan (judul + peringkat, tanpa poster/sinopsis).
TMDB_API_KEY=

# ── X / TikTok (embed konten, LOKAL) ─────────────────────────────
# Ambil "tweet teratas" per tren X (butuh login X di profil Chrome yang sama).
# Otomatis ON saat run_local.py. Di cloud biarkan 0 (tanpa browser login).
TWITTER_WITH_TWEETS=0
# Jumlah hashtag TikTok teratas yang dicarikan video (untuk embed).
TIKTOK_VIDEO_TOPN=10

# ── Telegram (notifikasi) ────────────────────────────────────────
TELEGRAM_BOT_TOKEN=
TELEGRAM_CHAT_ID=

# ── Umum ─────────────────────────────────────────────────────────
GEO=ID
LANG=id
# Set ke 1 untuk uji coba tanpa menulis ke D1 (hanya cetak ke konsol).
DRY_RUN=0
